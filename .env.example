# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-value
xi# Production behind SWAG must use APP_ENV=production, HTTPS PUBLIC_BASE_URL, and SECURE_COOKIES=true.
SECURE_COOKIES=false
ANALYSIS_PROVIDER=ollama
OLLAMA_URL=https://ollama.host.com
OLLAMA_MODEL=qwen3.6:35b
OLLAMA_VISION_MODEL=qwen3.6:35b
OLLAMA_TEXT_MODEL=
# Optional local-first fuzzy product index. Qdrant's HTTP endpoint is normally port 6333.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PRICE_COLLECTION=bourbonbook_prices
# Required only when ANALYSIS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
MAX_USERS=10
MAX_UPLOAD_MB=15
# Bounds the durable local catalog-import queue, staging, extraction, review, retry, and expiry flow.
CATALOG_IMPORT_MAX_FILES=5
CATALOG_IMPORT_MAX_TOTAL_MB=50
CATALOG_IMPORT_MAX_PDF_PAGES=10
CATALOG_IMPORT_SOURCE_EXPIRY_HOURS=24
DATA_DIR=./data
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:8000
EMAIL_DELIVERY_MODE=capture
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
# Set only in local .env or as a masked Unraid variable; never commit a real value.
SMTP_PASSWORD=
SMTP_FROM_EMAIL=bourbonbook@example.com
SMTP_FROM_NAME=Bourbon Book
SMTP_TLS_MODE=starttls
VERIFICATION_TTL_HOURS=24
RESET_TTL_MINUTES=60
# Required on first production startup only; remove the password after bootstrap.
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
PROXY_HEADERS=false
# Production must set this to SWAG's fixed container IP or the smallest proxy-network CIDR.
# Never use * in production.
FORWARDED_ALLOW_IPS=127.0.0.1
RATE_LIMIT_ATTEMPTS=8
RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_GLOBAL_ATTEMPTS=200
METRICS_ENABLED=true
API_USAGE_RETENTION_DAYS=90
LOG_LEVEL=INFO
LOG_FORMAT=text
